---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="تسجيل الدخول · التجميعة" description="سجل الدخول بحساب Google">
	<main class="login-main">
		<div class="login-card">
			<h1 class="login-title">تسجيل الدخول</h1>
			<p class="login-desc">
				سجل الدخول بحساب Google
			</p>
			<button class="google-btn" id="google-btn" type="button">
				<svg width="20" height="20" viewBox="0 0 48 48"><path fill="#FFC107" d="M43.611 20.083H42V20H24v8h11.303c-1.649 4.657-6.08 8-11.303 8-6.627 0-12-5.373-12-12s5.373-12 12-12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 12.955 4 4 12.955 4 24s8.955 20 20 20 20-8.955 20-20c0-1.341-.138-2.65-.389-3.917"/><path fill="#FF3D00" d="M6.306 14.691l6.571 4.819C14.655 15.108 18.961 12 24 12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 16.318 4 9.656 8.337 6.306 14.691"/><path fill="#4CAF50" d="M24 44c5.166 0 9.86-1.977 13.409-5.192l-6.19-5.238A11.91 11.91 0 0 1 24 36c-5.202 0-9.619-3.317-11.283-7.946l-6.522 5.025C9.505 39.556 16.227 44 24 44"/><path fill="#1976D2" d="M43.611 20.083H42V20H24v8h11.303a12.04 12.04 0 0 1-4.087 5.571l.003-.002 6.19 5.238C36.971 39.205 44 34 44 24c0-1.341-.138-2.65-.389-3.917"/></svg>
				تسجيل الدخول بـ Google
			</button>
			</div>
	</main>
</BaseLayout>

<script>
	import { getSupabase } from "../lib/supabase";

	const base = import.meta.env.BASE_URL;
	const params = new URLSearchParams(location.search);
	const redirect = params.get("redirect") || base + "/";

	const supabase = getSupabase();
	if (!supabase) {
		console.error("Supabase not configured");
	} else {
		supabase.auth.getSession().then(({ data }) => {
			if (data.session) {
				location.href = redirect;
			}
		});
	}

	document.getElementById("google-btn")?.addEventListener("click", async () => {
		const s = getSupabase();
		if (!s) {
			alert("لم يتم تهيئة الاتصال. تحقق من إعدادات Supabase.");
			return;
		}
		const redirectTo =
			location.origin +
			location.pathname +
			"?redirect=" +
			encodeURIComponent(redirect);
		const { error } = await s.auth.signInWithOAuth({
			provider: "google",
			options: { redirectTo },
		});
		if (error) alert("خطأ في تسجيل الدخول: " + error.message);
	});

	if (supabase) {
		supabase.auth.onAuthStateChange((event, session) => {
			if (session) {
				location.href = redirect;
			}
		});
	}
</script>

<style>
	.login-main {
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: calc(100vh - 200px);
		padding: var(--space-xl) var(--space-lg);
	}
	.login-card {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-lg);
		padding: var(--space-xxl) var(--space-xl);
		background: var(--surface);
		border-radius: var(--radius-md);
		box-shadow: var(--shadow-sm);
		max-width: 400px;
		width: 100%;
		text-align: center;
	}
	.login-title {
		font-size: 1.5rem;
		font-weight: 700;
		color: var(--ink);
	}
	.login-desc {
		font-size: 0.9375rem;
		color: var(--ink-muted);
		line-height: 1.6;
	}
	.google-btn {
		display: inline-flex;
		align-items: center;
		gap: var(--space-sm);
		padding: 10px 24px;
		background: #fff;
		color: #333;
		font-family: var(--font);
		font-size: 0.9375rem;
		font-weight: 600;
		line-height: 1.4;
		border: 1px solid var(--divider);
		border-radius: var(--radius-sm);
		cursor: pointer;
		transition: box-shadow 0.2s var(--ease-snappy);
	}
	.google-btn:hover {
		box-shadow: var(--shadow-md);
	}
	.google-btn:focus-visible {
		outline: 2px solid var(--warm-rust);
		outline-offset: 2px;
	}
	.login-note {
		font-size: 0.75rem;
		color: var(--ink-muted);
	}

	@media (max-width: 640px) {
		.login-main {
			padding: var(--space-lg) var(--space-md);
		}
		.login-card {
			padding: var(--space-xl) var(--space-lg);
		}
	}
</style>
