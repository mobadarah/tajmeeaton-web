---
import BaseLayout from "../layouts/BaseLayout.astro";
import { projects } from "../data/projects.json";
import {
	technologies as allTechnologies,
	tags as allTags,
	licenses as allLicenses,
} from "../data/schemas.json";

const statusOrder = { "نشط 🚀": 0, "متوقف صيانته 😑": 1, "ميت ☠️": 2 };
const sortedProjects = [...projects].sort((a, b) => {
	const sa = statusOrder[a.status] ?? 99;
	const sb = statusOrder[b.status] ?? 99;
	if (sa !== sb) return sa - sb;
	return (b.last_activity || "").localeCompare(a.last_activity || "");
});

const statuses = Object.keys(statusOrder);
const statusLabels = {
	"نشط 🚀": "نشط",
	"متوقف صيانته 😑": "متوقف",
	"ميت ☠️": "ميت",
};

const projectCount = projects.length;
const base = import.meta.env.BASE_URL;
const defaultDesc =
	"قائمة المشاريع التقنية وغير التقنية التي تهدف لتقديم النفع للأمة كهدف أساسي";
---

<BaseLayout title="التجميعة · القائمة" description={defaultDesc}>
  <header class="hero">
    <div class="hero-content">
      <h1 class="hero-title">التجميعة</h1>
      <p class="hero-subtitle">قائمة المشاريع التقنية وغير التقنية · {projectCount} مشروعاً</p>
      <a href={base + '/suggest/'} class="hero-cta">اقترح مشروعاً</a>
    </div>
  </header>

  <div class="toolbar" id="toolbar">
    <div class="toolbar-inner">
      <div class="search-wrap">
        <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
        <input class="search-input" type="search" id="search" placeholder="ابحث عن مشروع…" autocomplete="off">
      </div>
      <div class="toolbar-row">
        <div class="tags-scroll" id="tags-scroll">
          <div class="tags-row" id="tags-row">
            {allTags.map(tag => (
              <button class="tag-btn" data-tag={tag} type="button">{tag}</button>
            ))}
          </div>
        </div>

      </div>
    </div>
  </div>

  <div class="advanced-wrap">
    <div class="advanced-toggle-bar">
      <button class="advanced-toggle" id="advanced-toggle" type="button" aria-expanded="false" aria-controls="advanced-panel">
        <svg class="chevron-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        بحث متقدم
        <span class="filter-badge" id="filter-badge" hidden></span>
      </button>
    </div>
    <div class="advanced-panel" id="advanced-panel" role="region" aria-labelledby="advanced-toggle">
      <div class="panel-grid">
        <div class="panel-section">
          <h3 class="panel-heading">التقنيات</h3>
          <div class="panel-chips" id="tech-chips">
            {allTechnologies.map(tech => (
              <button class="chip-btn tech-btn" data-tech={tech} type="button">{tech}</button>
            ))}
          </div>
        </div>
        <div class="panel-section">
          <h3 class="panel-heading">الرخص</h3>
          <div class="panel-chips" id="license-chips">
            {allLicenses.map(license => (
              <button class="chip-btn license-btn" data-license={license} type="button">{license}</button>
            ))}
          </div>
        </div>
        <div class="panel-section">
          <h3 class="panel-heading">الحالة</h3>
          <div class="status-group" id="status-group">
            {statuses.map(s => (
              <label class="status-label">
                <input type="checkbox" class="status-cb" data-status={s}>
                <span>{statusLabels[s]}</span>
              </label>
            ))}
          </div>
        </div>
        <div class="panel-section">
          <h3 class="panel-heading">مصدر مفتوح</h3>
          <div class="oss-group" id="oss-group">
            <button class="oss-btn active" data-oss="" type="button">الكل</button>
            <button class="oss-btn" data-oss="Yes" type="button">مفتوح المصدر</button>
            <button class="oss-btn" data-oss="No" type="button">غير مفتوح</button>
          </div>
        </div>
      </div>
      <div class="panel-footer">
        <button class="panel-reset" id="panel-reset" type="button">إعادة تعيين البحث</button>
      </div>
    </div>
  </div>

  <main class="main">
    <div class="grid" id="grid">
      {sortedProjects.map(p => {
        const tags = p.tags || [];
        const technologies = p.technologies || [];
        const licenses = p.license ? [p.license] : [];
        const searchText = [p.name, p.description_ar, p.description_en, ...tags, ...technologies].filter(Boolean).join(' ').toLowerCase();
        return (
          <article class="card" data-tags={tags.join(',')} data-techs={technologies.join(',')} data-licenses={licenses.join(',')} data-status={p.status} data-oss={p.open_source} data-search={searchText}>
            <div class="card-header">
              <h2 class="card-title"><a href={base + '/projects/' + p.slug + '/'} class="card-link stretched-link">{p.name}</a></h2>
              <span class="card-status" data-status={p.status}>{p.status}</span>
            </div>
            <p class="card-desc">{p.description_ar || p.description_en}</p>
            <div class="card-meta">
              {tags.slice(0, 4).map(t => <span class="card-tag">{t}</span>)}
              {tags.length > 4 && <span class="card-tag card-tag-more">+{tags.length - 4}</span>}
            </div>
            <div class="card-footer">
              <a class="card-source" href={p.source_url || '#'} target="_blank" rel="noopener">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                المصدر
              </a>
              {p.license && <span class="card-license">{p.license}</span>}
            </div>
          </article>
        );
      })}
    </div>
    <div class="empty hide-empty" id="empty">
      <p class="empty-text">لا توجد مشاريع تطابق بحثك</p>
      <button class="empty-reset" id="reset-filters" type="button">إعادة تعيين البحث</button>
    </div>
  </main>

  <div class="pagination" id="pagination">
    <button class="page-btn" id="page-prev" type="button">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      السابق
    </button>
    <span class="page-info" id="page-info"></span>
    <button class="page-btn" id="page-next" type="button">
      التالي
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
  </div>

  <div class="footer-spacer"></div>
</BaseLayout>

<script>
  const search = document.getElementById('search');

  const params = new URLSearchParams(location.search);
  const qParam = params.get('q');
  if (qParam && search) {
    search.value = qParam;
  }

  const grid = document.getElementById('grid');
  const empty = document.getElementById('empty');
  const resetBtn = document.getElementById('reset-filters');
  const tagBtns = document.querySelectorAll('.tag-btn');
  const techBtns = document.querySelectorAll('.tech-btn');
  const licenseBtns = document.querySelectorAll('.license-btn');
  const statusCbs = document.querySelectorAll('.status-cb');
  const ossBtns = document.querySelectorAll('.oss-btn');
  const cards = document.querySelectorAll('.card');
  const advancedToggle = document.getElementById('advanced-toggle');
  const advancedPanel = document.getElementById('advanced-panel');
  const filterBadge = document.getElementById('filter-badge');
  const pagePrev = document.getElementById('page-prev');
  const pageNext = document.getElementById('page-next');
  const pageInfo = document.getElementById('page-info');
  const panelReset = document.getElementById('panel-reset');
  let hideDead = localStorage.getItem('hideDead') === 'true';

  let activeTags = new Set();
  let activeTechnologies = new Set();
  let activeLicenses = new Set();
  let activeStatuses = new Set();
  let openSourceFilter = '';
  let currentPage = 1;
  const ITEMS_PER_PAGE = 51;
  let filteredCards = [];

  function filter() {
    const query = (search?.value || '').trim().toLowerCase();
    const hideDead = localStorage.getItem('hideDead') === 'true';

    filteredCards = [];
    cards.forEach(card => {
      const searchText = card.dataset.search || '';
      const cardTags = (card.dataset.tags || '').split(',').filter(Boolean);
      const cardTechs = (card.dataset.techs || '').split(',').filter(Boolean);
      const cardLicenses = (card.dataset.licenses || '').split(',').filter(Boolean);
      const cardStatus = card.dataset.status || '';
      const cardOSS = card.dataset.oss || '';

      const matchesSearch = !query || searchText.includes(query);
      const matchesTags = activeTags.size === 0 || [...activeTags].every(t => cardTags.includes(t));
      const matchesTechs = activeTechnologies.size === 0 || [...activeTechnologies].every(t => cardTechs.includes(t));
      const matchesLicense = activeLicenses.size === 0 || [...activeLicenses].some(l => cardLicenses.includes(l));
      const matchesStatus = activeStatuses.size === 0 || activeStatuses.has(cardStatus);
      const matchesOSS = !openSourceFilter || cardOSS === openSourceFilter;
      const matchesAlive = !hideDead || cardStatus !== 'ميت ☠️';

      if (matchesSearch && matchesTags && matchesTechs && matchesLicense && matchesStatus && matchesOSS && matchesAlive) {
        filteredCards.push(card);
      }
    });

    currentPage = 1;
    showPage();
  }

  function showPage() {
    const totalFiltered = filteredCards.length;
    const totalPages = Math.ceil(totalFiltered / ITEMS_PER_PAGE) || 1;

    let visible = 0;
    cards.forEach(card => {
      const isFiltered = filteredCards.includes(card);
      if (!isFiltered) {
        card.classList.add('hide-card');
        return;
      }
      const pageIndex = filteredCards.indexOf(card);
      const pageStart = (currentPage - 1) * ITEMS_PER_PAGE;
      const show = pageIndex >= pageStart && pageIndex < pageStart + ITEMS_PER_PAGE;
      card.classList.toggle('hide-card', !show);
      if (show) visible++;
    });

    const hasVisible = visible > 0;
    empty.classList.toggle('hide-empty', hasVisible);
    grid.classList.toggle('hide-empty', !hasVisible);

    pagePrev.disabled = currentPage <= 1;
    pageNext.disabled = currentPage >= totalPages;
    pageInfo.textContent = hasVisible
      ? `الصفحة ${currentPage} من ${totalPages} (${totalFiltered} مشروعاً)`
      : '';

    const advancedCount = activeTechnologies.size + activeLicenses.size + activeStatuses.size + (openSourceFilter ? 1 : 0);
    if (advancedCount > 0) {
      filterBadge.textContent = advancedCount;
      filterBadge.hidden = false;
    } else {
      filterBadge.hidden = true;
    }
  }

  search?.addEventListener('input', filter);

  tagBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag;
      if (activeTags.has(tag)) {
        activeTags.delete(tag);
        btn.classList.remove('active');
      } else {
        activeTags.add(tag);
        btn.classList.add('active');
      }
      filter();
    });
  });

  techBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const tech = btn.dataset.tech;
      if (activeTechnologies.has(tech)) {
        activeTechnologies.delete(tech);
        btn.classList.remove('active');
      } else {
        activeTechnologies.add(tech);
        btn.classList.add('active');
      }
      filter();
    });
  });

  licenseBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const license = btn.dataset.license;
      if (activeLicenses.has(license)) {
        activeLicenses.delete(license);
        btn.classList.remove('active');
      } else {
        activeLicenses.add(license);
        btn.classList.add('active');
      }
      filter();
    });
  });

  statusCbs.forEach(cb => {
    cb.addEventListener('change', () => {
      const status = cb.dataset.status;
      if (cb.checked) {
        activeStatuses.add(status);
      } else {
        activeStatuses.delete(status);
      }
      filter();
    });
  });

  ossBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const value = btn.dataset.oss;
      if (openSourceFilter === value) {
        openSourceFilter = '';
      } else {
        openSourceFilter = value;
      }
      ossBtns.forEach(b => b.classList.toggle('active', b.dataset.oss === openSourceFilter));
      filter();
    });
  });

  advancedToggle?.addEventListener('click', () => {
    const isOpen = advancedToggle.getAttribute('aria-expanded') === 'true';
    advancedToggle.setAttribute('aria-expanded', String(!isOpen));
    advancedPanel.classList.toggle('open', !isOpen);
  });

  pagePrev?.addEventListener('click', () => {
    if (currentPage > 1) { currentPage--; showPage(); }
  });

  pageNext?.addEventListener('click', () => {
    const totalPages = Math.ceil(filteredCards.length / ITEMS_PER_PAGE) || 1;
    if (currentPage < totalPages) { currentPage++; showPage(); }
  });

  window.addEventListener('hideDeadChange', () => filter());

  function resetFilters() {
    activeTags.clear();
    activeTechnologies.clear();
    activeLicenses.clear();
    activeStatuses.clear();
    openSourceFilter = '';

    tagBtns.forEach(b => b.classList.remove('active'));
    techBtns.forEach(b => b.classList.remove('active'));
    licenseBtns.forEach(b => b.classList.remove('active'));
    statusCbs.forEach(cb => cb.checked = false);
    ossBtns.forEach(b => b.classList.toggle('active', b.dataset.oss === ''));

    if (search) search.value = '';
    filter();
  }

  resetBtn?.addEventListener('click', resetFilters);
  panelReset?.addEventListener('click', resetFilters);

  filter();
</script>

<style>
  .hide-card { display: none !important; }
  .hide-empty { display: none !important; }

  .hero {
    background: var(--warm-rust);
    color: #fff;
    padding: var(--space-xxl) var(--space-lg);
    text-align: center;
  }
  .hero-content {
    max-width: 720px;
    margin: 0 auto;
  }
  .hero-title {
    font-size: clamp(1.75rem, 5vw, 3rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-sm);
  }
  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 400;
    line-height: 1.5;
    color: oklch(0.85 0.04 35);
    max-width: 540px;
    margin: 0 auto var(--space-md);
  }
  .hero-cta {
    display: inline-flex;
    align-items: center;
    padding: 10px 24px;
    background: oklch(0.85 0.04 35 / 0.2);
    color: #fff;
    font-family: var(--font);
    font-size: 0.9375rem;
    font-weight: 600;
    line-height: 1.4;
    border-radius: var(--radius-sm);
    border: 1px solid oklch(0.85 0.04 35 / 0.3);
    transition: background 0.2s var(--ease-snappy);
  }
  .hero-cta:hover {
    background: oklch(0.85 0.04 35 / 0.3);
    text-decoration: none;
    color: #fff;
  }

  .toolbar {
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--page);
    border-bottom: 1px solid var(--divider);
  }
  .toolbar-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--space-md) var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  .search-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }
  .search-icon {
    position: absolute;
    right: 14px;
    color: var(--ink-muted);
    pointer-events: none;
  }
  .search-input {
    width: 100%;
    padding: 10px 40px 10px 14px;
    background: var(--surface);
    color: var(--ink);
    font-family: var(--font);
    font-size: 0.9375rem;
    line-height: 1.5;
    border: 1px solid var(--divider);
    border-radius: var(--radius-md);
    outline: none;
    transition: border-color 0.2s var(--ease-snappy);
  }
  .search-input::placeholder {
    color: var(--ink-muted);
  }
  .search-input:focus {
    border-color: var(--warm-rust);
  }
  .search-input:focus-visible {
    outline: 2px solid var(--warm-rust);
    outline-offset: 2px;
  }

  .toolbar-row {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }
  .settings-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    padding: 0;
    background: transparent;
    color: var(--ink-muted);
    border: 1px solid var(--divider);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: color 0.2s var(--ease-snappy), border-color 0.2s var(--ease-snappy);
  }
  .settings-btn:hover {
    color: var(--warm-rust);
    border-color: var(--warm-rust);
  }
  .settings-btn:focus-visible {
    outline: 2px solid var(--warm-rust);
    outline-offset: 2px;
  }

  .tags-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    flex: 1;
  }
  .tags-scroll::-webkit-scrollbar {
    display: none;
  }
  .tags-row {
    display: flex;
    gap: var(--space-sm);
    padding: var(--space-xs) 0;
    width: max-content;
  }
  .tag-btn {
    display: inline-flex;
    align-items: center;
    padding: 4px 14px;
    background: var(--warm-rust-tint);
    color: var(--warm-rust);
    font-family: var(--font);
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1.4;
    border: none;
    border-radius: var(--radius-pill);
    cursor: pointer;
    user-select: none;
    white-space: nowrap;
    transition: background 0.2s var(--ease-snappy), color 0.2s var(--ease-snappy);
  }
  .tag-btn:hover {
    background: var(--warm-rust-tint-hover);
  }
  .tag-btn.active {
    background: var(--warm-rust);
    color: #fff;
  }
  .tag-btn:focus-visible {
    outline: 2px solid var(--warm-rust);
    outline-offset: 2px;
  }

  .advanced-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--space-lg);
  }
  .advanced-toggle-bar {
    display: flex;
    justify-content: center;
    padding: var(--space-sm) 0;
  }
  .advanced-toggle {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 8px 20px;
    background: transparent;
    color: var(--ink-muted);
    font-family: var(--font);
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.4;
    border: 1px solid var(--divider);
    border-radius: var(--radius-pill);
    cursor: pointer;
    user-select: none;
    transition: color 0.2s var(--ease-snappy), border-color 0.2s var(--ease-snappy);
  }
  .advanced-toggle:hover {
    color: var(--warm-rust);
    border-color: var(--warm-rust);
  }
  .advanced-toggle:focus-visible {
    outline: 2px solid var(--warm-rust);
    outline-offset: 2px;
  }
  .chevron-icon {
    transition: transform 0.2s var(--ease-snappy);
  }
  .advanced-toggle[aria-expanded="true"] .chevron-icon {
    transform: rotate(-90deg);
  }
  .filter-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 20px;
    height: 20px;
    padding: 0 6px;
    background: var(--warm-rust);
    color: #fff;
    font-size: 0.6875rem;
    font-weight: 700;
    line-height: 1;
    border-radius: var(--radius-pill);
  }

  .advanced-panel {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s var(--ease-out), padding 0.3s var(--ease-out);
    padding: 0;
  }
  .advanced-panel.open {
    max-height: 600px;
    padding: var(--space-lg) 0;
  }
  .panel-grid {
    display: grid;
    gap: var(--space-lg);
  }
  .panel-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  .panel-heading {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--ink-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .panel-chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    max-height: 160px;
    overflow-y: auto;
  }
  .chip-btn {
    display: inline-flex;
    align-items: center;
    padding: 4px 12px;
    background: var(--surface);
    color: var(--ink-muted);
    font-family: var(--font);
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1.4;
    border: 1px solid var(--divider);
    border-radius: var(--radius-pill);
    cursor: pointer;
    user-select: none;
    white-space: nowrap;
    transition: background 0.2s var(--ease-snappy), color 0.2s var(--ease-snappy), border-color 0.2s var(--ease-snappy);
  }
  .chip-btn:hover {
    border-color: var(--warm-rust);
    color: var(--warm-rust);
  }
  .chip-btn.active {
    background: var(--warm-rust-tint);
    color: var(--warm-rust);
    border-color: var(--warm-rust);
  }
  .chip-btn:focus-visible {
    outline: 2px solid var(--warm-rust);
    outline-offset: 2px;
  }

  .status-group {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }
  .status-label {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: 0.875rem;
    color: var(--ink);
    cursor: pointer;
    user-select: none;
  }
  .status-label input {
    width: 18px;
    height: 18px;
    accent-color: var(--warm-rust);
    cursor: pointer;
  }

  .oss-group {
    display: flex;
    gap: var(--space-xs);
    flex-wrap: wrap;
  }
  .oss-btn {
    display: inline-flex;
    align-items: center;
    padding: 6px 16px;
    background: var(--surface);
    color: var(--ink-muted);
    font-family: var(--font);
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1.4;
    border: 1px solid var(--divider);
    border-radius: var(--radius-pill);
