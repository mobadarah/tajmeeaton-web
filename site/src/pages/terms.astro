---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="شروط الاستخدام · التجميعة" description="شروط استخدام منصة التجميعة">
	<header class="hero">
		<div class="hero-content">
			<h1 class="hero-title">شروط الاستخدام</h1>
			<p class="hero-subtitle">آخر تحديث بتاريخ ١٢ يونيو ٢٠٢٦</p>
		</div>
	</header>

	<main class="main">
		<div class="card">
			<p class="lead">
				باستخدامك لمنصة <strong>التجميعة</strong>، فإنك تقرّ بموافقتك على
				الشروط التالية والتزامك بها.
			</p>

			<section>
				<h2>وصف المنصة</h2>
				<p>
					التجميعة هي قائمة مفتوحة للمشاريع التقنية وغير التقنية التي تهدف لتقديم
					النفع للأمة. تُعرض المشاريع كما يقدمها أصحابها أو المقترحون لها، دون أن
					يعني ذلك تبنّي المنصة لأي مشروع أو محتوى منشور.
				</p>
			</section>

		<section>
			<h2>المحتوى المقدم</h2>
			<p>
				عند تقديم اقتراح لإضافة مشروع عبر نموذج الاقتراح، يقرّ المقدّم بأن جميع
				المعلومات التي يقدمها دقيقة وصحيحة قدر علمه، ويتحمل كامل المسؤولية عن
				صحة هذه البيانات. يحتفظ القائمون على المنصة بحقهم في قبول أو رفض أو تعديل
				أي اقتراح دون إبداء أسباب.
			</p>
		</section>

		<section>
			<h2>الحسابات والمصادقة</h2>
			<p>
				يتيح الموقع تسجيل الدخول عبر حساب Google لتقديم الاقتراحات والملاحظات.
				نحن نجمع فقط المعلومات العامة المتاحة من موفر المصادقة (الاسم والبريد
				الإلكتروني وصورة الملف الشخصي)، وتستخدم هذه المعلومات حصراً لعرض هويتك
				على المنصة. أنت المسؤول الوحيد عن نشاط حسابك.
			</p>
		</section>

			<section>
				<h2>المشاريع الخارجية</h2>
				<p>
					الروابط الخارجية للمشاريع المدرجة في التجميعة تخضع لشروط وأحكام وسياسات
					الخصوصية الخاصة بها. لا تتحمل المنصة أي مسؤولية عن محتوى هذه المشاريع أو
					تحديثاتها أو توفرها.
				</p>
			</section>

			<section>
				<h2>حقوق الملكية الفكرية</h2>
				<p>
					جميع المشاريع المدرجة في التجميعة مملوكة لأصحابها. الكود المصدري للمنصة
					نفسها متاح تحت رخصة
					<a href="https://github.com/mobadarah/tajmeeaton-web/blob/main/LICENSE" target="_blank" rel="noopener">MIT</a>
					على
					<a href="https://github.com/mobadarah/tajmeeaton-web" target="_blank" rel="noopener">GitHub</a>.
				</p>
			</section>

			<section>
				<h2>إخلاء المسؤولية</h2>
				<p>
					تُقدّم المنصة والمحتوى المدرج فيها "كما هي" دون أي ضمانات، صريحة أو
					ضمنية. لا نتحمل أي مسؤولية عن أي أضرار مباشرة أو غير مباشرة قد تنجم عن
					استخدام المنصة أو الاعتماد على المعلومات المدرجة فيها.
				</p>
			</section>

			<section>
				<h2>حقوق الإدارة</h2>
				<p>
					تحتفظ إدارة المنصة بحقها الكامل في حذف أو تعديل أي مشروع أو محتوى ترى
					أنه مخالف لهذه الشروط، أو غير مناسب، أو لأي سبب آخر، وذلك دون إشعار مسبق.
				</p>
			</section>

			<section>
				<h2>التعديلات على الشروط</h2>
				<p>
					نحتفظ بحقنا في تحديث شروط الاستخدام هذه في أي وقت. سيتم نشر أي تغييرات
					على هذه الصفحة، ويعتبر استمرارك في استخدام المنصة بعد التحديث موافقة
					ضمنية على الشروط المعدّلة.
				</p>
			</section>

		<section>
			<h2>التواصل</h2>
			<p>
				للاستفسارات المتعلقة بشروط الاستخدام، يمكنك التواصل عبر
				زر الملاحظات في الزاوية السفلية اليسرى، أو عبر
				<a href="https://github.com/mobadarah/tajmeeaton-web/issues" target="_blank" rel="noopener">صفحة المشكلات على GitHub</a>.
			</p>
		</section>
		</div>
	</main>
</BaseLayout>

<style>

	.main {
		max-width: 720px;
		margin: 0 auto;
		padding: var(--space-xl) var(--space-lg) var(--space-xxl);
	}
	.card {
		background: var(--surface);
		border-radius: var(--radius-md);
		box-shadow: var(--shadow-sm);
		padding: var(--space-xl);
	}
	.lead {
		font-size: 1.0625rem;
		line-height: 1.7;
		color: var(--ink);
		margin-bottom: var(--space-lg);
		padding-bottom: var(--space-lg);
		border-bottom: 1px solid var(--divider);
	}
	section {
		margin-bottom: var(--space-lg);
	}
	section:last-child {
		margin-bottom: 0;
	}
	h2 {
		font-size: 1.125rem;
		font-weight: 700;
		color: var(--ink);
		margin-bottom: var(--space-sm);
		line-height: 1.3;
	}
	p {
		font-size: 0.9375rem;
		line-height: 1.7;
		color: var(--ink-muted);
	}

	@media (max-width: 640px) {
		.main { padding: var(--space-md) var(--space-md) var(--space-xl); }
		.card { padding: var(--space-lg) var(--space-md); }
	}
</style>
