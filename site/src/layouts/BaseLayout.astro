---
export interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description, image } = Astro.props;
const siteUrl = 'https://arabic-projects.example.com';
const defaultDesc = 'قائمة المشاريع العربية مفتوحة المصدر · دليل شامل للمشاريع التقنية العربية';
---

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description || defaultDesc} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description || defaultDesc} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={Astro.url} />
  {image && <meta property="og:image" content={image} />}
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="canonical" href={siteUrl + Astro.url.pathname} />
  <link rel="icon" href="/favicon.ico" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --warm-rust: oklch(0.48 0.10 35);
      --warm-rust-hover: oklch(0.40 0.10 35);
      --warm-rust-active: oklch(0.34 0.10 35);
      --warm-rust-tint: oklch(0.93 0.03 35);
      --warm-rust-tint-hover: oklch(0.88 0.04 35);
      --gold-leaf: oklch(0.68 0.10 70);
      --page: oklch(0.97 0.003 250);
      --surface: #ffffff;
      --ink: oklch(0.12 0.01 35);
      --ink-muted: oklch(0.48 0.02 35);
      --divider: oklch(0.89 0.008 35);
      --green: oklch(0.55 0.12 150);
      --amber: oklch(0.65 0.15 85);
      --radius-sm: 6px;
      --radius-md: 10px;
      --radius-lg: 14px;
      --radius-pill: 999px;
      --font: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
      --ease-snappy: cubic-bezier(0.25, 0.1, 0.25, 1);
      --ease-out: cubic-bezier(0.25, 1, 0.5, 1);
      --space-xs: 4px;
      --space-sm: 8px;
      --space-md: 16px;
      --space-lg: 24px;
      --space-xl: 32px;
      --space-xxl: 48px;
    }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--font);
      background: var(--page);
      color: var(--ink);
      line-height: 1.6;
      min-height: 100vh;
    }
    a { color: var(--warm-rust); text-decoration: none; }
    a:hover { text-decoration: underline; }
    img { max-width: 100%; height: auto; display: block; }
    ::selection { background: var(--warm-rust); color: #fff; }
    h1, h2, h3 { text-wrap: balance; }
    p { text-wrap: pretty; }
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>
