---
export interface Props {
	title: string;
	description?: string;
	image?: string;
}

const { title, description, image } = Astro.props;
const base = import.meta.env.BASE_URL;
const defaultDesc =
	"قائمة المشاريع التقنية وغير التقنية التي تهدف لتقديم النفع للأمة كهدف أساسي";
---

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description || defaultDesc} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description || defaultDesc} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={Astro.url} />
  {image && <meta property="og:image" content={image} />}
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="canonical" href={Astro.url} />
  <link rel="icon" href={base + '/favicon.ico'} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Nastaliq+Urdu:wght@400;600;700&display=swap" rel="stylesheet" />
  <script>
    (function() {
      var theme = localStorage.getItem('theme');
      if (!theme) {
        theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      }
      if (theme === 'dark') {
        document.documentElement.setAttribute('data-theme', 'dark');
      }
    })();
  </script>
  <style is:global>
    @font-face {
      font-family: 'Thamaneyah Serif Text';
      src: url('/fonts/thmanyah-serif-text-light.woff2') format('woff2');
      font-weight: 300;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'Thamaneyah Serif Text';
      src: url('/fonts/thmanyah-serif-text-regular.woff2') format('woff2');
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'Thamaneyah Serif Text';
      src: url('/fonts/thmanyah-serif-text-medium.woff2') format('woff2');
      font-weight: 500;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'Thamaneyah Serif Text';
      src: url('/fonts/thmanyah-serif-text-bold.woff2') format('woff2');
      font-weight: 700;
      font-style: normal;
      font-display: swap;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --warm-rust: oklch(0.48 0.10 35);
      --warm-rust-hover: oklch(0.40 0.10 35);
      --warm-rust-active: oklch(0.34 0.10 35);
      --warm-rust-tint: oklch(0.93 0.03 35);
      --warm-rust-tint-hover: oklch(0.88 0.04 35);
      --gold-leaf: oklch(0.68 0.10 70);
      --page: oklch(0.97 0.003 250);
      --surface: #ffffff;
      --ink: oklch(0.12 0.01 35);
      --ink-muted: oklch(0.48 0.02 35);
      --divider: oklch(0.89 0.008 35);
      --green: oklch(0.55 0.12 150);
      --amber: oklch(0.65 0.15 85);
      --radius-sm: 2px;
      --radius-md: 4px;
      --radius-lg: 8px;
      --radius-pill: 999px;
      --shadow-sm: 0 1px 2px oklch(0 0 0 / 0.06);
      --shadow-md: 0 1px 3px oklch(0 0 0 / 0.07), 0 1px 2px oklch(0 0 0 / 0.04);
      --shadow-lg: 0 2px 8px oklch(0 0 0 / 0.07), 0 1px 3px oklch(0 0 0 / 0.04);
      --card-hover: oklch(0.93 0.03 35 / 0.3);
      --status-active-bg: oklch(0.88 0.05 150 / 0.3);
      --status-active-text: oklch(0.40 0.12 150);
      --status-paused-bg: oklch(0.88 0.05 85 / 0.3);
      --status-paused-text: oklch(0.45 0.12 85);
      --status-dead-bg: oklch(0.88 0.03 30 / 0.2);
      --status-dead-text: var(--ink-muted);
      --font: 'Thamaneyah Serif Text', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
      --font-display: 'Noto Nastaliq Urdu', 'Thamaneyah Serif Text', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
      --ease-snappy: cubic-bezier(0.25, 0.1, 0.25, 1);
      --ease-out: cubic-bezier(0.25, 1, 0.5, 1);
      --space-xs: 4px;
      --space-sm: 8px;
      --space-md: 16px;
      --space-lg: 24px;
      --space-xl: 32px;
      --space-xxl: 48px;
    }
    :root[data-theme="dark"] {
      --warm-rust: oklch(0.62 0.12 35);
      --warm-rust-hover: oklch(0.55 0.12 35);
      --warm-rust-active: oklch(0.48 0.12 35);
      --warm-rust-tint: oklch(0.25 0.04 35);
      --warm-rust-tint-hover: oklch(0.30 0.04 35);
      --page: oklch(0.14 0.008 35);
      --surface: oklch(0.18 0.01 35);
      --ink: oklch(0.92 0.005 35);
      --ink-muted: oklch(0.62 0.01 35);
      --divider: oklch(0.25 0.01 35);
      --shadow-sm: 0 1px 2px oklch(0 0 0 / 0.3);
      --shadow-md: 0 1px 3px oklch(0 0 0 / 0.35), 0 1px 2px oklch(0 0 0 / 0.25);
      --shadow-lg: 0 2px 8px oklch(0 0 0 / 0.35), 0 1px 3px oklch(0 0 0 / 0.25);
      --card-hover: oklch(0.24 0.03 35);
      --status-active-bg: oklch(0.45 0.10 150 / 0.35);
      --status-active-text: var(--ink);
      --status-paused-bg: oklch(0.50 0.12 85 / 0.35);
      --status-paused-text: var(--ink);
      --status-dead-bg: oklch(0.30 0.03 30 / 0.35);
      --status-dead-text: var(--ink-muted);
    }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--font);
      background: var(--page);
      color: var(--ink);
      line-height: 1.6;
      min-height: 100vh;
    }
    a { color: var(--warm-rust); text-decoration: none; }
    a:hover { text-decoration: underline; }
    img { max-width: 100%; height: auto; display: block; }
    ::selection { background: var(--warm-rust); color: #fff; }
    h1, h2, h3 { text-wrap: balance; }
    p { text-wrap: pretty; }
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
    }
  .feedback-btn {
    position: fixed;
    bottom: 24px;
    left: 24px;
    z-index: 30;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--warm-rust);
    color: #fff;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 12px rgba(0,0,0,0.15);
    transition: transform 0.2s var(--ease-snappy), box-shadow 0.2s var(--ease-snappy);
  }
  .feedback-btn:hover {
    transform: scale(1.1);
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
  }
  .feedback-btn:focus-visible {
    outline: 2px solid var(--warm-rust);
    outline-offset: 3px;
  }

  .feedback-overlay {
    position: fixed;
    inset: 0;
    z-index: 40;
    background: rgba(0,0,0,0.4);
  }

  .feedback-modal {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 50;
    width: 90%;
    max-width: 440px;
    background: var(--surface);
    border-radius: var(--radius-md);
    box-shadow: 0 8px 40px rgba(0,0,0,0.18);
    direction: rtl;
  }
  .feedback-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid var(--divider);
  }
  .feedback-modal-header h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--ink);
  }
  .feedback-close {
    background: none;
    border: none;
    font-size: 1.5rem;
    color: var(--ink-muted);
    cursor: pointer;
    line-height: 1;
    padding: 0;
  }
  .feedback-close:hover {
    color: var(--ink);
  }
  .feedback-modal-body {
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .feedback-modal-body label {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--ink-muted);
  }
  .feedback-modal-body input,
  .feedback-modal-body textarea {
    width: 100%;
    padding: 10px 12px;
    font-family: var(--font);
    font-size: 0.875rem;
    color: var(--ink);
    background: var(--bg);
    border: 1px solid var(--divider);
    border-radius: var(--radius-sm);
    resize: vertical;
    box-sizing: border-box;
  }
  .feedback-modal-body input:focus,
  .feedback-modal-body textarea:focus {
    outline: none;
    border-color: var(--warm-rust);
    box-shadow: 0 0 0 2px rgba(179, 89, 58, 0.15);
  }
  .feedback-msg {
    font-size: 0.8125rem;
    color: var(--warm-rust);
    min-height: 1.2em;
  }
  .feedback-modal-footer {
    padding: 12px 20px;
    border-top: 1px solid var(--divider);
    display: flex;
    justify-content: flex-end;
  }
  .feedback-submit {
    padding: 8px 24px;
    background: var(--warm-rust);
    color: #fff;
    font-family: var(--font);
    font-size: 0.875rem;
    font-weight: 600;
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: opacity 0.2s var(--ease-snappy);
  }
  .feedback-submit:hover {
    opacity: 0.9;
  }
  .feedback-submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .feedback-submit:focus-visible {
    outline: 2px solid var(--warm-rust);
    outline-offset: 2px;
  }

  @media (max-width: 640px) {
    .feedback-btn {
      bottom: 16px;
      left: 16px;
      width: 44px;
      height: 44px;
    }
    .feedback-modal {
      width: 96%;
    }
  }
</style>
</head>
<body>
  <header class="site-header">
    <div class="header-inner">
      <div class="header-start">
        <a href={base} class="site-logo">التجميعة</a>
        <a href={base + '/dictionary/'} class="nav-link">المعجم</a>
        <a href={base + '/suggest/'} class="nav-link">اقترح مشروعاً</a>
      </div>
      <form class="header-search" action={base} method="GET" role="search">
        <svg class="header-search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
        <input class="header-search-input" type="search" name="q" placeholder="ابحث عن مشروع…" aria-label="ابحث عن مشروع" autocomplete="off" />
      </form>
      <div class="header-end">
        <div class="header-auth" id="header-auth">
          <a href={base + '/login/'} class="header-login-link" id="header-login-link">تسجيل الدخول</a>
          <div class="header-user" id="header-user" hidden>
            <button class="header-avatar-btn" id="header-avatar-btn" type="button" aria-label="قائمة المستخدم">
              <img class="header-avatar-img" id="header-avatar-img" src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" alt="" hidden />
            </button>
            <div class="header-dropdown" id="header-dropdown" hidden>
              <span class="header-dropdown-name" id="header-dropdown-name"></span>
              <button class="header-dropdown-logout" id="header-dropdown-logout" type="button">تسجيل الخروج</button>
            </div>
          </div>
        </div>
        <button class="settings-btn" id="settings-btn" type="button" aria-label="الإعدادات">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
        </button>
      </div>
    </div>
  </header>
  <dialog class="settings-modal" id="settings-modal">
    <div class="settings-header">
      <h2 class="settings-title">الإعدادات</h2>
      <button class="settings-close" id="settings-close" type="button" aria-label="إغلاق">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="settings-body">
      <div class="settings-group">
        <span class="settings-label">المظهر</span>
        <div class="theme-toggle" id="theme-toggle">
          <button class="theme-btn" data-theme="light" type="button">فاتح</button>
          <button class="theme-btn" data-theme="dark" type="button">داكن</button>
        </div>
      </div>
      <div class="settings-group">
        <span class="settings-label">المشاريع الميتة</span>
        <label class="toggle-row">
          <input type="checkbox" id="hide-dead">
          <span>إخفاء المشاريع الميتة من القائمة</span>
        </label>
      </div>
    </div>
  </dialog>
  <script>
    const settingsBtn = document.getElementById('settings-btn');
    const settingsModal = document.getElementById('settings-modal');
    const settingsClose = document.getElementById('settings-close');
    const themeBtns = document.querySelectorAll('.theme-btn');
    const hideDeadCb = document.getElementById('hide-dead');

    settingsBtn?.addEventListener('click', () => settingsModal?.showModal());
    settingsClose?.addEventListener('click', () => settingsModal?.close());
    settingsModal?.addEventListener('click', (e) => {
      if (e.target === settingsModal) settingsModal.close();
    });

    themeBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const theme = btn.dataset.theme;
        document.documentElement.setAttribute('data-theme', theme);
        localStorage.setItem('theme', theme);
        themeBtns.forEach(b => b.classList.toggle('active', b.dataset.theme === theme));
      });
    });

    if (hideDeadCb) {
      hideDeadCb.checked = localStorage.getItem('hideDead') === 'true';
      hideDeadCb.addEventListener('change', () => {
        localStorage.setItem('hideDead', String(hideDeadCb.checked));
        window.dispatchEvent(new CustomEvent('hideDeadChange', { detail: hideDeadCb.checked }));
      });
    }

    (function initTheme() {
      const theme = document.documentElement.getAttribute('data-theme') || 'light';
      themeBtns.forEach(b => b.classList.toggle('active', b.dataset.theme === theme));
    })();
  </script>
  <script>
    import { getSupabase } from "../lib/supabase";

    const supabase = getSupabase();

    const headerLoginLink = document.getElementById("header-login-link");
    const headerUser = document.getElementById("header-user");
    const headerAvatarImg = document.getElementById("header-avatar-img");
    const headerAvatarBtn = document.getElementById("header-avatar-btn");
    const headerDropdown = document.getElementById("header-dropdown");
    const headerDropdownName = document.getElementById("header-dropdown-name");
    const headerDropdownLogout = document.getElementById("header-dropdown-logout");

    async function updateHeaderAuth() {
      if (!supabase) return;
      const { data } = await supabase.auth.getSession();
      const user = data.session?.user;

      if (user) {
        headerLoginLink?.setAttribute("hidden", "");
        headerUser?.removeAttribute("hidden");
        const avatarUrl = user.user_metadata?.avatar_url;
        if (avatarUrl) {
          headerAvatarImg.src = avatarUrl;
          headerAvatarImg.removeAttribute("hidden");
        } else {
          headerAvatarImg.setAttribute("hidden", "");
        }
        headerAvatarImg.alt = user.user_metadata?.full_name || "";
        headerDropdownName.textContent =
          user.user_metadata?.full_name || user.email || "";
      } else {
        headerLoginLink?.removeAttribute("hidden");
        headerUser?.setAttribute("hidden", "");
        headerDropdown?.setAttribute("hidden", "");
        headerAvatarImg?.setAttribute("hidden", "");
      }
    }

    headerAvatarBtn?.addEventListener("click", (e) => {
      e.stopPropagation();
      const isHidden = headerDropdown?.hasAttribute("hidden");
      if (isHidden) {
        headerDropdown?.removeAttribute("hidden");
      } else {
        headerDropdown?.setAttribute("hidden", "");
      }
    });

    document.addEventListener("click", () => {
      headerDropdown?.setAttribute("hidden", "");
    });

    headerDropdownLogout?.addEventListener("click", async () => {
      headerDropdown?.setAttribute("hidden", "");
      if (supabase) {
        await supabase.auth.signOut();
      }
      updateHeaderAuth();
    });

    if (supabase) {
      supabase.auth.onAuthStateChange(() => {
        updateHeaderAuth();
      });
    }

    updateHeaderAuth();

    /* ── Feedback button ── */
    const feedbackBtn = document.getElementById("feedback-btn");
    const feedbackModal = document.getElementById("feedback-modal");
    const feedbackOverlay = document.getElementById("feedback-overlay");
    const feedbackClose = document.getElementById("feedback-close");
    const feedbackSubmit = document.getElementById("feedback-submit");
    const feedbackTitle = document.getElementById("feedback-title");
    const feedbackBody = document.getElementById("feedback-body");
    const feedbackMsg = document.getElementById("feedback-msg");

    const FEEDBACK_DAILY_LIMIT = 10;

    async function feedbackTodayCount(supabase) {
      const startOfDay = new Date();
      startOfDay.setHours(0, 0, 0, 0);
      const { count } = await supabase
        .from("suggestions")
        .select("id", { count: "exact", head: true })
        .gte("created_at", startOfDay.toISOString());
      return count || 0;
    }

    feedbackBtn?.addEventListener("click", () => {
      feedbackOverlay?.removeAttribute("hidden");
      feedbackModal?.removeAttribute("hidden");
      document.body.style.overflow = "hidden";
    });

    function closeFeedback() {
      feedbackOverlay?.setAttribute("hidden", "");
      feedbackModal?.setAttribute("hidden", "");
      document.body.style.overflow = "";
      feedbackMsg.textContent = "";
      feedbackTitle.value = "";
      feedbackBody.value = "";
    }

    feedbackClose?.addEventListener("click", closeFeedback);
    feedbackOverlay?.addEventListener("click", closeFeedback);

    feedbackSubmit?.addEventListener("click", async () => {
      const title = feedbackTitle.value.trim();
      const body = feedbackBody.value.trim();
      if (!title || !body) {
        feedbackMsg.textContent = "يرجى ملء الحقلين";
        return;
      }

      const s = getSupabase();
      if (!s) {
        feedbackMsg.textContent = "لم يتم تهيئة الاتصال";
        return;
      }

      const { data: { session } } = await s.auth.getSession();
      if (!session) {
        feedbackMsg.textContent = "يجب تسجيل الدخول أولاً";
        return;
      }

      const todayCount = await feedbackTodayCount(s);
      if (todayCount >= FEEDBACK_DAILY_LIMIT) {
        feedbackMsg.textContent = "لقد تجاوزت الحد اليومي (١٠)";
        return;
      }

      feedbackSubmit.disabled = true;
      feedbackSubmit.textContent = "جارٍ الإرسال…";

      const { error } = await s.from("suggestions").insert({
        user_id: session.user.id,
        name: title,
        description_ar: body,
      });

      feedbackSubmit.disabled = false;
      feedbackSubmit.textContent = "إرسال";

      if (error) {
        feedbackMsg.textContent = "حدث خطأ: " + error.message;
        return;
      }

      feedbackMsg.textContent = "✓ تم الإرسال";
      feedbackTitle.value = "";
      feedbackBody.value = "";
      setTimeout(closeFeedback, 1500);
    });
  </script>
  <slot />
  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <span class="footer-logo">التجميعة</span>
        <p class="footer-tagline">قائمة المشاريع التقنية وغير التقنية التي تهدف لتقديم النفع للأمة</p>
      </div>
      <div class="footer-links">
        <a href={base} class="footer-link">الرئيسية</a>
        <a href={base + '/dictionary/'} class="footer-link">المعجم</a>
        <a href={base + '/suggest/'} class="footer-link">اقترح مشروعاً</a>
        <a href="https://github.com/mobadarah/tajmeeaton-web" class="footer-link" target="_blank" rel="noopener">المصدر على GitHub</a>
        <a href={base + '/privacy/'} class="footer-link">سياسة الخصوصية</a>
        <a href={base + '/terms/'} class="footer-link">شروط الاستخدام</a>
      </div>
      <div class="footer-copy">
        © {new Date().getFullYear()} — التجميعة
      </div>
    </div>
  </footer>

  <button class="feedback-btn" id="feedback-btn" type="button" aria-label="أرسل ملاحظاتك">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
  </button>

  <div class="feedback-overlay" id="feedback-overlay" hidden></div>
  <div class="feedback-modal" id="feedback-modal" role="dialog" aria-modal="true" aria-labelledby="feedback-modal-title" hidden>
    <div class="feedback-modal-header">
      <h3 id="feedback-modal-title">أرسل ملاحظاتك</h3>
      <button class="feedback-close" id="feedback-close" type="button" aria-label="إغلاق">&times;</button>
    </div>
    <div class="feedback-modal-body">
      <label for="feedback-title">العنوان</label>
