---
export interface Props {
	title: string;
	description?: string;
	image?: string;
}

const { title, description, image } = Astro.props;
const base = import.meta.env.BASE_URL;
const defaultDesc =
	"قائمة المشاريع التقنية وغير التقنية التي تهدف لتقديم النفع للأمة كهدف أساسي";
---

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description || defaultDesc} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description || defaultDesc} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={Astro.url} />
  {image && <meta property="og:image" content={image} />}
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="canonical" href={Astro.url} />
  <link rel="icon" href={base + '/favicon.ico'} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Nastaliq+Urdu:wght@400;600;700&display=swap" rel="stylesheet" />
  <script>
    (function() {
      var theme = localStorage.getItem('theme');
      if (!theme) {
        theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      }
      if (theme === 'dark') {
        document.documentElement.setAttribute('data-theme', 'dark');
      }
    })();
  </script>
  <style is:global>
    @font-face {
      font-family: 'Thamaneyah Serif Text';
      src: url('/fonts/thmanyah-serif-text-light.woff2') format('woff2');
      font-weight: 300;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'Thamaneyah Serif Text';
      src: url('/fonts/thmanyah-serif-text-regular.woff2') format('woff2');
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'Thamaneyah Serif Text';
      src: url('/fonts/thmanyah-serif-text-medium.woff2') format('woff2');
      font-weight: 500;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'Thamaneyah Serif Text';
      src: url('/fonts/thmanyah-serif-text-bold.woff2') format('woff2');
      font-weight: 700;
      font-style: normal;
      font-display: swap;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --warm-rust: oklch(0.48 0.10 35);
      --warm-rust-hover: oklch(0.40 0.10 35);
      --warm-rust-active: oklch(0.34 0.10 35);
      --warm-rust-tint: oklch(0.93 0.03 35);
      --warm-rust-tint-hover: oklch(0.88 0.04 35);
      --gold-leaf: oklch(0.68 0.10 70);
      --page: oklch(0.97 0.003 250);
      --surface: #ffffff;
      --ink: oklch(0.12 0.01 35);
      --ink-muted: oklch(0.48 0.02 35);
      --divider: oklch(0.89 0.008 35);
      --green: oklch(0.55 0.12 150);
      --amber: oklch(0.65 0.15 85);
      --radius-sm: 2px;
      --radius-md: 4px;
      --radius-lg: 8px;
      --radius-pill: 999px;
      --shadow-sm: 0 1px 2px oklch(0 0 0 / 0.06);
      --shadow-md: 0 1px 3px oklch(0 0 0 / 0.07), 0 1px 2px oklch(0 0 0 / 0.04);
      --shadow-lg: 0 2px 8px oklch(0 0 0 / 0.07), 0 1px 3px oklch(0 0 0 / 0.04);
      --card-hover: oklch(0.93 0.03 35 / 0.3);
      --status-active-bg: oklch(0.88 0.05 150 / 0.3);
      --status-active-text: oklch(0.40 0.12 150);
      --status-paused-bg: oklch(0.88 0.05 85 / 0.3);
      --status-paused-text: oklch(0.45 0.12 85);
      --status-dead-bg: oklch(0.88 0.03 30 / 0.2);
      --status-dead-text: var(--ink-muted);
      --font: 'Thamaneyah Serif Text', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
      --font-display: 'Noto Nastaliq Urdu', 'Thamaneyah Serif Text', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
      --ease-snappy: cubic-bezier(0.25, 0.1, 0.25, 1);
      --ease-out: cubic-bezier(0.25, 1, 0.5, 1);
      --space-xs: 4px;
      --space-sm: 8px;
      --space-md: 16px;
      --space-lg: 24px;
      --space-xl: 32px;
      --space-xxl: 48px;
    }
    :root[data-theme="dark"] {
      --warm-rust: oklch(0.62 0.12 35);
      --warm-rust-hover: oklch(0.55 0.12 35);
      --warm-rust-active: oklch(0.48 0.12 35);
      --warm-rust-tint: oklch(0.25 0.04 35);
      --warm-rust-tint-hover: oklch(0.30 0.04 35);
      --page: oklch(0.14 0.008 35);
      --surface: oklch(0.18 0.01 35);
      --ink: oklch(0.92 0.005 35);
      --ink-muted: oklch(0.62 0.01 35);
      --divider: oklch(0.25 0.01 35);
      --shadow-sm: 0 1px 2px oklch(0 0 0 / 0.3);
      --shadow-md: 0 1px 3px oklch(0 0 0 / 0.35), 0 1px 2px oklch(0 0 0 / 0.25);
      --shadow-lg: 0 2px 8px oklch(0 0 0 / 0.35), 0 1px 3px oklch(0 0 0 / 0.25);
      --card-hover: oklch(0.24 0.03 35);
      --status-active-bg: oklch(0.45 0.10 150 / 0.35);
      --status-active-text: var(--ink);
      --status-paused-bg: oklch(0.50 0.12 85 / 0.35);
      --status-paused-text: var(--ink);
      --status-dead-bg: oklch(0.30 0.03 30 / 0.35);
      --status-dead-text: var(--ink-muted);
    }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--font);
      background: var(--page);
      color: var(--ink);
      line-height: 1.6;
      min-height: 100vh;
    }
    a { color: var(--warm-rust); text-decoration: none; }
    a:hover { text-decoration: underline; }
    img { max-width: 100%; height: auto; display: block; }
    ::selection { background: var(--warm-rust); color: #fff; }
    h1, h2, h3 { text-wrap: balance; }
    p { text-wrap: pretty; }
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
    }
  </style>
</head>
<body>
  <header class="site-header">
    <div class="header-inner">
      <a href={base} class="site-logo">التجميعة</a>
      <form class="header-search" action={base} method="GET" role="search">
        <svg class="header-search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
        <input class="header-search-input" type="search" name="q" placeholder="ابحث عن مشروع…" aria-label="ابحث عن مشروع" autocomplete="off" />
      </form>
      <button class="settings-btn" id="settings-btn" type="button" aria-label="الإعدادات">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
      </button>
    </div>
  </header>
  <dialog class="settings-modal" id="settings-modal">
    <div class="settings-header">
      <h2 class="settings-title">الإعدادات</h2>
      <button class="settings-close" id="settings-close" type="button" aria-label="إغلاق">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="settings-body">
      <div class="settings-group">
        <span class="settings-label">المظهر</span>
        <div class="theme-toggle" id="theme-toggle">
          <button class="theme-btn" data-theme="light" type="button">فاتح</button>
          <button class="theme-btn" data-theme="dark" type="button">داكن</button>
        </div>
      </div>
      <div class="settings-group">
        <span class="settings-label">المشاريع الميتة</span>
        <label class="toggle-row">
          <input type="checkbox" id="hide-dead">
          <span>إخفاء المشاريع الميتة من القائمة</span>
        </label>
      </div>
    </div>
  </dialog>
  <script>
    const settingsBtn = document.getElementById('settings-btn');
    const settingsModal = document.getElementById('settings-modal');
    const settingsClose = document.getElementById('settings-close');
    const themeBtns = document.querySelectorAll('.theme-btn');
    const hideDeadCb = document.getElementById('hide-dead');

    settingsBtn?.addEventListener('click', () => settingsModal?.showModal());
    settingsClose?.addEventListener('click', () => settingsModal?.close());
    settingsModal?.addEventListener('click', (e) => {
      if (e.target === settingsModal) settingsModal.close();
    });

    themeBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const theme = btn.dataset.theme;
        document.documentElement.setAttribute('data-theme', theme);
        localStorage.setItem('theme', theme);
        themeBtns.forEach(b => b.classList.toggle('active', b.dataset.theme === theme));
      });
    });

    if (hideDeadCb) {
      hideDeadCb.checked = localStorage.getItem('hideDead') === 'true';
      hideDeadCb.addEventListener('change', () => {
        localStorage.setItem('hideDead', String(hideDeadCb.checked));
        window.dispatchEvent(new CustomEvent('hideDeadChange', { detail: hideDeadCb.checked }));
      });
    }

    (function initTheme() {
      const theme = document.documentElement.getAttribute('data-theme') || 'light';
      themeBtns.forEach(b => b.classList.toggle('active', b.dataset.theme === theme));
    })();
  </script>
  <slot />
  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <span class="footer-logo">التجميعة</span>
        <p class="footer-tagline">قائمة المشاريع التقنية وغير التقنية التي تهدف لتقديم النفع للأمة</p>
      </div>
      <div class="footer-links">
        <a href={base} class="footer-link">الرئيسية</a>
        <a href="https://github.com/mobadarah/tajmeeaton-web" class="footer-link" target="_blank" rel="noopener">المصدر على GitHub</a>
      </div>
      <div class="footer-copy">
        © {new Date().getFullYear()} — التجميعة
      </div>
    </div>
  </footer>
</body>
<style is:global>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: var(--surface);
    border-bottom: 1px solid var(--divider);
  }
  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 14px var(--space-lg);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
  }
  .site-logo {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--ink);
    white-space: nowrap;
    text-decoration: none;
  }
  .site-logo:hover {
    text-decoration: none;
    color: var(--warm-rust);
  }
  .header-search {
    position: relative;
    flex: 1;
    max-width: 360px;
  }
  .header-search-icon {
    position: absolute;
    top: 50%;
    inset-inline-start: 12px;
    translate: 0 -50%;
    color: var(--ink-muted);
    pointer-events: none;
  }
  .header-search-input {
    width: 100%;
    padding: 7px 36px 7px 12px;
    background: var(--page);
    color: var(--ink);
    font-family: var(--font);
    font-size: 0.875rem;
    line-height: 1.5;
    border: 1px solid var(--divider);
    border-radius: var(--radius-md);
    outline: none;
    transition: border-color 0.2s var(--ease-snappy);
  }
  .header-search-input::placeholder {
    color: var(--ink-muted);
  }
  .header-search-input:focus {
    border-color: var(--warm-rust);
  }
  .header-search-input:focus-visible {
    outline: 2px solid var(--warm-rust);
    outline-offset: 2px;
  }

  .settings-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    padding: 0;
    background: transparent;
    color: var(--ink-muted);
    border: 1px solid var(--divider);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: color 0.2s var(--ease-snappy), border-color 0.2s var(--ease-snappy);
  }
  .settings-btn:hover {
    color: var(--warm-rust);
    border-color: var(--warm-rust);
  }
  .settings-btn:focus-visible {
    outline: 2px solid var(--warm-rust);
    outline-offset: 2px;
  }

  .settings-modal {
    max-width: 400px;
    width: calc(100% - 32px);
    padding: 0;
    background: var(--surface);
    color: var(--ink);
    border: none;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    font-family: var(--font);
  }
  .settings-modal::backdrop {
    background: oklch(0 0 0 / 0.4);
  }
  .settings-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-lg);
    border-bottom: 1px solid var(--divider);
  }
  .settings-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--ink);
  }
  .settings-close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    padding: 0;
    background: transparent;
    color: var(--ink-muted);
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: color 0.2s var(--ease-snappy);
  }
  .settings-close:hover {
    color: var(--ink);
  }
  .settings-close:focus-visible {
    outline: 2px solid var(--warm-rust);
    outline-offset: 2px;
  }
  .settings-body {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }
  .settings-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  .settings-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--ink-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .theme-toggle {
    display: flex;
    gap: var(--space-xs);
  }
  .theme-btn {
    flex: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 8px 16px;
    background: var(--surface);
    color: var(--ink-muted);
    font-family: var(--font);
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.4;
    border: 1px solid var(--divider);
    border-radius: var(--radius-sm);
    cursor: pointer;
    user-select: none;
    transition: color 0.2s var(--ease-snappy), border-color 0.2s var(--ease-snappy), background 0.2s var(--ease-snappy);
  }
  .theme-btn:hover {
    border-color: var(--warm-rust);
    color: var(--warm-rust);
  }
  .theme-btn.active {
    background: var(--warm-rust);
    color: #fff;
    border-color: var(--warm-rust);
  }
  .theme-btn:focus-visible {
    outline: 2px solid var(--warm-rust);
    outline-offset: 2px;
  }
  .toggle-row {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.875rem;
    color: var(--ink);
    cursor: pointer;
    user-select: none;
  }
  .toggle-row input {
    width: 18px;
    height: 18px;
    accent-color: var(--warm-rust);
    cursor: pointer;
  }

  .site-footer {
    border-top: 1px solid var(--divider);
    margin-top: var(--space-xxl);
  }
  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--space-xl) var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }
  .footer-logo {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--ink);
  }
  .footer-tagline {
    font-size: 0.8125rem;
    color: var(--ink-muted);
  }
  .footer-links {
    display: flex;
    gap: var(--space-lg);
  }
  .footer-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ink-muted);
    transition: color 0.2s var(--ease-snappy);
  }
  .footer-link:hover {
    color: var(--warm-rust);
    text-decoration: none;
  }
  .footer-copy {
    font-size: 0.75rem;
    color: var(--ink-muted);
    padding-top: var(--space-md);
    border-top: 1px solid var(--divider);
  }

  @media (max-width: 640px) {
    .header-inner {
      padding: 10px var(--space-md);
    }
    .header-search {
      max-width: none;
    }
    .footer-inner {
      padding: var(--space-lg) var(--space-md);
    }
    .footer-links {
      flex-direction: column;
      gap: var(--space-sm);
    }
  }
</style>
</html>
